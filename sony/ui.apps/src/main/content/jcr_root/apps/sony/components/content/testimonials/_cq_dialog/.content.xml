<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Testimonials"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <cards
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Testimonials"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        granite:class="cq-RichText-FixedColumn-column"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <cards
                                                granite:class="mf-validate"
                                                jcr:primaryType="nt:unstructured"
                                                jcr:title="Testimonials"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                                composite="{Boolean}true"
                                                fieldDescription="Add testimonial cards. Minimum 1 and Maximum 3 cards allowed."
                                                fieldLabel="Testimonials">
                                                <field
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title=" Cards"
                                                    sling:resourceType="granite/ui/components/foundation/container"
                                                    name="./cardList">
                                                    <layout
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/foundation/layouts/collapsible"/>
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <quotetext
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                                            fieldDescription="Enter the testimonial quote text. Maximum 300 characters."
                                                            fieldLabel="Quote Text"
                                                            maxlength="{Long}300"
                                                            name="./cardDescription"
                                                            required="{Boolean}true">
                                                            <granite:data
                                                                jcr:primaryType="nt:unstructured"
                                                                minlength="{Long}10"/>
                                                        </quotetext>
                                                        <name
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldDescription="Enter the name of the person giving the testimonial."
                                                            fieldLabel="Name"
                                                            name="./name"/>
                                                        <title
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldDescription="Enter the title or designation of the person."
                                                            fieldLabel="Title"
                                                            name="./cardTitle"/>
                                                        <thumnailimage
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="cq/gui/components/authoring/dialog/fileupload"
                                                            allowUpload="{Boolean}false"
                                                            class="cq-droptarget"
                                                            fieldDescription="Upload the thumbnail image for the testimonial."
                                                            fieldLabel="Thumbnail Image"
                                                            fileNameParameter="./fileName"
                                                            fileReferenceParameter="./thumbnailImage"
                                                            mimeTypes="[image/jpeg,image/png,image/tiff,image/svg+xml,image/webp]"
                                                            name="./thumbnailImages"/>
                                                        <disablelazyloading
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                            checked="false"
                                                            fieldDescription="Disable the lazy loading of the image in Testimonials"
                                                            name="./disableLazyLoading"
                                                            text="Disable Lazy Loading"
                                                            value="{Boolean}true"/>
                                                        <alttext
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldDescription="Enter the Alt text for the thumbnail image."
                                                            fieldLabel="Image Alt text"
                                                            name="./altText"/>
                                                    </items>
                                                </field>
                                                <granite:data
                                                    jcr:primaryType="nt:unstructured"
                                                    max="{Long}3"
                                                    min="{Long}1"/>
                                            </cards>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </cards>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
